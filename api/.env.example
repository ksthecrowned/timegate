# Install / run (from ./api): bun install | bun run prisma:migrate | bun run prisma:seed | bun run start:dev
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/timegate?schema=public"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="8h"
MOBILE_LIFETIME_TOKEN_EXPIRES_IN="100y"
MOBILE_VERIFY_CONCURRENCY=6
DUPLICATE_ATTENDANCE_WINDOW_SECONDS=300

# Face engine (Python dlib / face_recognition)
#
# Windows recommendation (Option A):
# - Install Python 3.11 or 3.12 x64 (avoid 3.14 for dlib wheels/toolchain pain)
# - Create a venv in ./api/.venv and install requirements:
#     bash scripts/setup-face-venv.sh
#   Then point FACE_ENGINE_PYTHON_BIN to that interpreter (see below).
# - If `import face_recognition` asks for `face_recognition_models`, run:
#     .venv/Scripts/python.exe -m pip install -r python/requirements.txt

# Face verification threshold for cosine similarity
FACE_VERIFY_THRESHOLD=0.82

# Python binary used by API to spawn face engine
# Windows venv example (adjust to your absolute repo path if needed):
# FACE_ENGINE_PYTHON_BIN="D:/TimeGate/api/.venv/Scripts/python.exe"
FACE_ENGINE_PYTHON_BIN="python"
# Optional absolute path to python/face_engine.py (if omitted, default is ./python/face_engine.py)
# FACE_ENGINE_SCRIPT_PATH=""
# Timeout for face extraction call
FACE_ENGINE_TIMEOUT_MS=10000

# Cloudflare R2 (recognition photos storage)
# Endpoint format: https://<accountid>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""
# Public base URL used by dashboard to display images
# Example: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
CLOUDFLARE_R2_PUBLIC_BASE_URL=""
